{
  "name": "frontend-universe",
  "version": "1.0.0",
  "description": "Frontend Universe - 前端全景宇宙：多层动态可视化前端技术栈展示",
  "main": "index.html",
  "scripts": {
    "dev": "live-server --port=3000 --open=/index.html",
    "build": "npm run minify-css && npm run minify-js",
    "minify-css": "cleancss -o dist/styles.min.css styles/*.css",
    "minify-js": "uglifyjs scripts/*.js -o dist/scripts.min.js",
    "serve": "http-server -p 8080 -o"
  },
  "keywords": [
    "frontend",
    "visualization",
    "animation",
    "tech-stack",
    "interactive",
    "demo"
  ],
  "author": "Frontend Universe Team",
  "license": "MIT",
  "devDependencies": {
    "live-server": "^1.2.2",
    "http-server": "^14.1.1",
    "clean-css-cli": "^5.6.2",
    "uglify-js": "^3.17.4"
  },
  "dependencies": {
    "three": "^0.158.0",
    "gsap": "^3.12.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/frontend-universe/demo"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}